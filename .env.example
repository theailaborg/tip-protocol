# TIP Protocol Node Configuration
# Copy this file to .env and customise before starting the node.
# NEVER commit .env to version control.

# ─── Node Identity ────────────────────────────────────────────────────────────

# Node environment
NODE_ENV=development

# Node identifier (auto-generated from hostname if not set)
TIP_NODE_ID=

# Node type: full | light | vp | archive
TIP_NODE_TYPE=full

# Node region
TIP_REGION=US

# ─── Network ─────────────────────────────────────────────────────────────────

# REST API port
PORT=4000

# Bind address
HOST=0.0.0.0

# Public URL (used in API responses)
TIP_PUBLIC_URL=http://localhost:4000

# ─── P2P / Consensus ────────────────────────────────────────────────────────

# libp2p P2P port (Narwhal/Bullshark consensus)
TIP_P2P_PORT=4001

# Public IP address of this node (for bootstrap_addr in health endpoint)
# Other nodes use this to connect. Required for remote/cloud deployments.
# Find your IP:
#   macOS:   ipconfig getifaddr en0
#   Linux:   hostname -I | awk '{print $1}'
#   Windows: ipconfig | findstr "IPv4"
#   Cloud:   curl -s ifconfig.me
TIP_PUBLIC_IP=

# Comma-separated libp2p bootstrap peer multiaddrs
# Get from the seed node's health endpoint: GET /health → data.p2p.bootstrap_addr
# Example: /ip4/203.0.113.50/tcp/4001/p2p/12D3KooWAbCdEf...
TIP_BOOTSTRAP_PEERS=

# Enable mDNS peer discovery (auto-discovers peers on same local network)
# Set to false for cloud/remote deployments — use TIP_BOOTSTRAP_PEERS instead
TIP_ENABLE_MDNS=true

# ─── Storage ─────────────────────────────────────────────────────────────────

# Data directory
TIP_DATA_DIR=./data

# SQLite database path
TIP_DB_PATH=./data/tip.db

# ─── Security ────────────────────────────────────────────────────────────────

# Node ML-DSA-65 signing keypair (hex-encoded)
# Generated by: scripts/seed.js (founding node) or scripts/register-node.js (additional nodes)
# Without these, the node cannot participate in consensus or sign transactions.
TIP_NODE_PRIVATE_KEY=
TIP_NODE_PUBLIC_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated allowed origins (* for development only)
TIP_CORS_ORIGINS=*

# ─── Logging ─────────────────────────────────────────────────────────────────
#
# Two thresholds, independent:
#   TIP_LOG_LEVEL     — max level written to logs/{date}/info.log
#   TIP_CONSOLE_LEVEL — max level printed to the terminal / docker logs
#
# debug.log ALWAYS captures every level regardless of these settings, so you
# can investigate any time without restarting. error.log captures errors only.
#
# Recommended production setup:
#   TIP_LOG_LEVEL=info       (info.log keeps the operator-relevant stream)
#   TIP_CONSOLE_LEVEL=warn   (terminal stays quiet — only warnings/errors)
#
# For local development:
#   TIP_LOG_LEVEL=info
#   TIP_CONSOLE_LEVEL=info   (default — see what's happening as you work)
#
# When investigating a bug:
#   TIP_CONSOLE_LEVEL=debug  (firehose on terminal — or just tail debug.log)
#
# Levels (highest to lowest verbosity): debug > info > warn > error
# Setting a level shows that level AND all more-severe levels.
#
# Log level for info.log file (default: info)
TIP_LOG_LEVEL=info

# Log level for console output (default: same as TIP_LOG_LEVEL, falls back to info)
# Set to `warn` in production to keep the terminal quiet — the full stream is
# still captured in logs/{date}/debug.log for post-mortem.
TIP_CONSOLE_LEVEL=warn
TIP_LOG_DIR=./logs/node-1