# TIP Protocol Node — copy to `.env` and customise. NEVER commit .env to git.

# ─── Node Identity ──────────────────────────────────────────────────────────
NODE_ENV=development                       # development | staging | production
TIP_NODE_ID=                               # auto-generated from hostname if blank
TIP_NODE_TYPE=full                         # full | light | vp | archive
TIP_REGION=US

# ─── Network ────────────────────────────────────────────────────────────────
PORT=4000                                  # REST API port
HOST=0.0.0.0                               # bind address
TIP_PUBLIC_URL=http://localhost:4000       # public URL surfaced in API responses
TIP_P2P_PORT=4001                          # libp2p port for Narwhal/Bullshark consensus

# Public IP used for peer dial-back. Required for cloud / multi-host setups.
# Find: macOS `ipconfig getifaddr en0` · Linux `hostname -I` · cloud `curl ifconfig.me`
TIP_PUBLIC_IP=

# Comma-separated bootstrap multiaddrs (from a peer's GET /health → data.p2p.bootstrap_addr).
# Example: /ip4/203.0.113.50/tcp/4001/p2p/12D3KooWAbCdEf...
TIP_BOOTSTRAP_PEERS=

# mDNS auto-discovery — true on a single LAN, false in the cloud.
TIP_ENABLE_MDNS=true

# ─── Storage ────────────────────────────────────────────────────────────────
TIP_DATA_DIR=./data                        # local artifacts (data dir, etc.)
TIP_DB_PATH=./data/tip.db                  # SQLite file path (only used if DB_DRIVER=sqlite)

# ─── Media Storage (image/audio bytes for prescan + reviewer access) ────────
# Backend: fs = local filesystem (dev default) · s3 = AWS S3 (prod).
# Storage is PER-NODE — each operator pays for and serves their own bucket.
# Provision the S3 side with infra/s3-media (terraform) — its outputs are
# exactly the four TIP_MEDIA_* values below. See docs/PROD_S3_SETUP.md.
TIP_MEDIA_BACKEND=fs
TIP_MEDIA_FS_PATH=./data/media             # fs backend root
TIP_MEDIA_S3_BUCKET=                       # s3 backend: bucket name
TIP_MEDIA_S3_REGION=us-west-2
TIP_MEDIA_S3_KMS_KEY_ID=                   # KMS key ARN for SSE-KMS
TIP_MEDIA_PRESIGN_TTL_SEC=300              # presigned-URL lifetime for reviewer fetches

# AWS credentials for the s3 backend. Prefer AMBIENT credentials (EC2
# instance profile / EKS IRSA / Roles Anywhere): leave these empty and the
# SDK finds them itself. Only set these when using setup.sh trust_mode=keys
# (the bucket-scoped IAM user; rotate every 90 days). Never the account
# owner's keys.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Retention sweep — deletes media bytes per the on-chain policy
# (21d never-disputed / 7d after adjudication / 7d after appeal result,
# orphan uploads after 24h). Runs every 6h by default. The windows are
# genesis constants; these knobs only control the sweep runtime.
# TIP_MEDIA_RETENTION_DISABLE=1            # turn the sweep off entirely
# TIP_MEDIA_RETENTION_SWEEP_INTERVAL_MS=60000   # fast cadence for testing

# This node's public API origin (https://host[:port], no path). Announced
# on chain ~15s after boot (NODE_ENDPOINT_UPDATED) so peers can 307
# reviewers here for media this node holds. The announce probe requires
# {url}/health to answer as THIS node — typos never reach the chain.
# Leave blank for nodes without a public surface.
TIP_API_ENDPOINT=

# ─── Database ───────────────────────────────────────────────────────────────
# Switching engines = change DB_DRIVER + connection vars below. No code edits.
#
#   sqlite     better-sqlite3   local dev only, no DB server needed
#   postgres   pg               production default
#   mariadb    mysql2           also accepts: mysql (alias)
#   mssql      mssql            also accepts: sqlserver (alias)
#   oracle     oracledb         thin-mode, no Oracle Instant Client required
#
# Default (when DB_DRIVER is unset) follows NODE_ENV:
#   production / staging → postgres        development / test → sqlite
DB_DRIVER=postgres

# Picks which DB service `docker compose up -d` brings up alongside the node.
# Empty = no DB service (SQLite only). Override per-run with --profile <name>.
COMPOSE_PROFILES=postgres

# Connection. DB_HOST = compose service name in Docker (postgres / mariadb /
# mssql / oracle), or `localhost` when running natively against host-side DB.
# Leave DB_PORT blank for driver default (5432 / 3306 / 1433 / 1521).
DB_HOST=localhost
DB_PORT=
DB_NAME=tip_protocol
DB_USER=tip
DB_PASSWORD=

# TLS — required for any cloud / managed DB. Set REJECT_UNAUTHORIZED=false
# only in private networks with self-signed certs.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Connection pool (server-side drivers only).
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Per-engine quick reference ──────────────────────────────────────────────
# PostgreSQL:  DB_HOST=postgres   DB_PORT=5432   (DB_NAME=tip_protocol default)
# MariaDB:     DB_HOST=mariadb    DB_PORT=3306
# Oracle:      DB_HOST=oracle     DB_PORT=1521   DB_NAME=FREEPDB1 (service name)
# SQL Server:  DB_HOST=mssql      DB_PORT=1433   DB_PASSWORD complexity rules:
#              uppercase + lowercase + digit + symbol, min 8. Avoid '#' (comment).
#              Cloud MSSQL usually needs DB_SSL=true.

# ─── Security — Node Keys ───────────────────────────────────────────────────
# ML-DSA-65 keypair, hex-encoded. Without these the node can't sign txs or
# participate in consensus. Generated by:
#   scripts/seed.js          → founding node
#   scripts/register-node.js → additional nodes (delivered in <slug>.env bundle)
TIP_NODE_PRIVATE_KEY=
TIP_NODE_PUBLIC_KEY=

# ─── Logging ────────────────────────────────────────────────────────────────
# Two thresholds, independent. debug.log always captures EVERYTHING regardless
# (post-mortem firehose); error.log captures errors only.
#
#   TIP_LOG_LEVEL      max level written to logs/<date>/info.log
#   TIP_CONSOLE_LEVEL  max level printed to terminal / docker logs
#
# Levels (verbose → quiet): debug > info > warn > error.
# Default below is `warn` for both — quiet on healthy federations.
# Flip to `info` or `debug` while investigating.
TIP_LOG_LEVEL=warn
TIP_CONSOLE_LEVEL=warn
TIP_LOG_DIR=./logs/node-1                  # per-node dir; multi-node hosts use ./logs/node-2 etc.

# ─── CORS ───────────────────────────────────────────────────────────────────
TIP_CORS_ORIGINS=*                         # comma-separated origins; '*' for dev only

# ─── AI Classifier ──────────────────────────────────────────────────────────
# Base URL of the TIP Protocol AI classifier service (FastAPI). When unset
# (or unreachable at call time) the node keeps accepting registrations in
# LOCAL FALLBACK mode — see TIP_CLASSIFIER_FALLBACK below.
TIP_CLASSIFIER_URL=http://localhost:6060
TIP_CLASSIFIER_KEY=                        # X-TIP-Classifier-Key header; blank = dev mode (no auth)

# Local fallback when the classifier is missing or unreachable (default ON):
#   text        → local heuristic verdict (same preScanContent function)
#   image/audio → stub neutral 0.5 ("no signal")
# Verdicts are tagged provider=local_fallback / classifier_version=
# local_fallback_v1 on chain so they're distinguishable from real scores.
# Boot + per-call warnings make the degraded mode visible in logs.
# Set to 0 for strict mode: no classifier → no prescan worker; content
# waits in PENDING_PRESCAN for the cross-node fail-open trigger.
TIP_CLASSIFIER_FALLBACK=1

# Default behaviour: only OH-declared content is sent to the classifier —
# AA/AG/MX self-disclose AI involvement so the classifier's job (catch
# undisclosed AI) doesn't apply. Setting this to `true` overrides that and
# sends AA/AG/MX through the classifier too. Useful when:
#   - You want to fact-check creator self-disclosure (e.g. catch an AA
#     declaration that's actually fully AG).
#   - You're seeding training data with classifier scores across all origins.
# Costs more classifier calls. Keep `false` in prod unless you've decided
# this trade-off is worth it.
TIP_CLASSIFIER_SCAN_NON_OH=false

# Max in-flight jobs each prescan worker processes concurrently. Classifier
# calls are IO-bound (just awaiting HTTP), so one worker can comfortably
# handle 4-8 at once without CPU pressure. Default 1 keeps the legacy
# sequential behaviour. Per-worker setting — multiply by
# TIP_PRESCAN_WORKER_COUNT for total parallelism.
#
# IMPORTANT: this value should match your classifier's throughput. With a
# SINGLE classifier instance doing CPU inference (the dev default), 4
# concurrent calls overload it — calls hit the 60s text timeout and retry
# uselessly. Recommendations:
#   - Single dev classifier:                   1 (sequential, safe)
#   - Classifier with GPU + batched inference: 2-4
#   - Load-balanced classifier (N replicas):   up to N
# When in doubt, leave at 1 and scale up after measuring classifier latency.
TIP_PRESCAN_CONCURRENCY=1

# Number of prescan worker instances to run in this API process. Each
# instance independently polls the shared queue and respects its own
# TIP_PRESCAN_CONCURRENCY. Atomic SQLite UPDATE…RETURNING claim prevents
# two workers from picking the same job. Useful when you want isolation
# (one slow classifier call doesn't block other workers' free slots)
# without sibling processes. Default 1.
TIP_PRESCAN_WORKER_COUNT=1

# Opt out of running the prescan worker in the API process — set when
# you want the worker as a separate process (docker-compose / pm2) while
# keeping the API focused on serving HTTP. The DB-backed queue is shared,
# so a sibling worker process picks up the same jobs.
# TIP_PRESCAN_WORKER_DISABLE=1

# ─── Dev-only flags ─────────────────────────────────────────────────────────
# Each flag requires BOTH the value below AND NODE_ENV != "production" — set
# either condition and the flag is silently ignored. Never enable in prod.
#
#   TIP_DEV_BYPASS_VOTE_WINDOWS     skip commit/reveal wall-clock checks so the
#                                   full dispute → verdict flow can be driven
#                                   without waiting the 72h+6h windows.
#   TIP_DEV_ALLOW_LOCALHOST_DOMAINS allow `localhost` / `127.0.0.1` (with
#                                   optional :PORT) as a bindable domain in
#                                   /v1/domain/register and the well-known
#                                   verifier — uses HTTP (not HTTPS) for
#                                   loopback hosts.
#   TIP_DEV_LOCALHOST_FETCH_HOST    rewrite host of loopback fetch URLs to
#                                   reach the host from inside a container.
#                                   Typical: `host.docker.internal` (Docker
#                                   Desktop) or `172.17.0.1` (Linux gateway).
#                                   Only the URL host changes; signed
#                                   `domain` + body comparison stay as the
#                                   claimed loopback name.
#   TIP_DEV_FORCE_PRESCAN_TIER      override the AI pre-scan output so every
#                                   OH/AA registration lands as HIGH or CRITICAL
#                                   tier. Lets you exercise the reviewer flow
#                                   end-to-end without crafting AI-looking
#                                   content. Accepts: "high" | "critical" |
#                                   "random" (50/50 HIGH/CRITICAL per call).
#                                   Leave blank in prod / for honest tests.
TIP_DEV_BYPASS_VOTE_WINDOWS=0
TIP_DEV_ALLOW_LOCALHOST_DOMAINS=0
TIP_DEV_LOCALHOST_FETCH_HOST=
TIP_DEV_FORCE_PRESCAN_TIER=random
