# TIP Protocol Node Configuration
# Copy this file to .env and customise before starting the node.
# NEVER commit .env to version control.

# ─── Node Identity ────────────────────────────────────────────────────────────

# Node environment
NODE_ENV=development

# Node identifier (auto-generated from hostname if not set)
# TIP_NODE_ID=

# Node type: full | light | vp | archive
TIP_NODE_TYPE=full

# Node region
TIP_REGION=US

# VP identifier (set only if this node is a Verification Provider)
# TIP_VP_ID=

# ─── Network ─────────────────────────────────────────────────────────────────

# REST API port
PORT=4000

# Bind address
HOST=0.0.0.0

# Public URL (used in peer announcements)
TIP_PUBLIC_URL=http://localhost:4000

# Comma-separated list of gossip peer addresses
TIP_PEERS=

# ─── Storage ─────────────────────────────────────────────────────────────────

# Data directory (SQLite DB, genesis data)
TIP_DATA_DIR=./data

# SQLite database path
TIP_DB_PATH=./data/tip.db

# ─── Security ────────────────────────────────────────────────────────────────

# Node ML-DSA-65 signing keypair (hex-encoded)
# If not set, an ephemeral keypair is generated at startup (won't survive restart)
# Generate: node -e "const c = require('./shared/crypto'); c.initCrypto().then(() => { const kp = c.generateMLDSAKeypair(); console.log('TIP_NODE_PRIVATE_KEY=' + kp.privateKey); console.log('TIP_NODE_PUBLIC_KEY=' + kp.publicKey); })"
TIP_NODE_PRIVATE_KEY=
TIP_NODE_PUBLIC_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated allowed origins (* for development only)
TIP_CORS_ORIGINS=*

# ─── Logging ─────────────────────────────────────────────────────────────────

# Log level: error | warn | info | debug
TIP_LOG_LEVEL=info
