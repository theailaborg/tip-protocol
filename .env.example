# TIP Protocol Node: copy to `.env` and customise. NEVER commit .env to git.

# ─── Node Identity ───────────────────────────────────────────────────────────
NODE_ENV=development                        # development | staging | production
TIP_NODE_ID=                                # auto-generated from hostname if blank
TIP_NODE_TYPE=full                          # full | light | vp | archive
TIP_REGION=US

# ─── Node Keys ───────────────────────────────────────────────────────────────
# ML-DSA-65 keypair, minted by scripts/seed.js (founding) or register-node.js.
# Supply ONE of, in priority order:
#   1. TIP_NODE_CREDENTIALS_FILE: .tip.json holding both keys (what generated nodes use)
#   2. TIP_NODE_PRIVATE_KEY_FILE=/run/secrets/...: mounted secret (Docker/K8s)
#   3. Inline keys (dev only). Public key is on-chain, not secret.
TIP_NODE_CREDENTIALS_FILE=
TIP_NODE_PRIVATE_KEY=
TIP_NODE_PUBLIC_KEY=

# ─── Network ─────────────────────────────────────────────────────────────────
PORT=4000                                   # REST API port
HOST=0.0.0.0
TIP_PUBLIC_URL=http://localhost:4000        # public URL surfaced in API responses
TIP_P2P_PORT=4001                           # libp2p port for consensus
TIP_PUBLIC_IP=                              # public IP for peer dial-back (cloud/multi-host)
TIP_BOOTSTRAP_PEERS=                        # comma-separated multiaddrs (peer's /health -> p2p.bootstrap_addr)
TIP_PEERS=                                  # legacy static list; prefer TIP_BOOTSTRAP_PEERS
TIP_ENABLE_MDNS=true                        # LAN auto-discovery; false in cloud

# Public API origin announced on chain at boot (https://host[:port], no path).
# The announce probe requires {url}/health to answer as THIS node.
TIP_API_ENDPOINT=

# ─── Database ────────────────────────────────────────────────────────────────
# sqlite (dev) | postgres (prod default) | mariadb | mssql | oracle.
DB_DRIVER=postgres
DATABASE_URL=                               # connection string; overrides DB_* below when set

# DB_HOST: compose service name in Docker, `localhost` natively,
# `host.docker.internal` for a host-shared DB from inside a container.
DB_HOST=localhost
DB_PORT=                                    # blank = driver default (5432 / 3306 / 1433 / 1521)
DB_NAME=tip_protocol
DB_USER=tip
DB_PASSWORD=
DB_SSL=false                                # true for any cloud/managed DB
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MIN=2
DB_POOL_MAX=10
# Oracle: DB_NAME=FREEPDB1 (service name). MSSQL: password needs upper+lower+
# digit+symbol min 8, avoid '#'; cloud MSSQL usually needs DB_SSL=true.

# ─── Storage ─────────────────────────────────────────────────────────────────
TIP_DATA_DIR=./data
TIP_DB_PATH=./data/tip.db                   # sqlite file (DB_DRIVER=sqlite only)

# ─── Media Storage ───────────────────────────────────────────────────────────
# fs = local disk (dev), s3 = AWS S3 (prod; provision via infra/s3-media/setup.sh).
TIP_MEDIA_BACKEND=fs
TIP_MEDIA_FS_PATH=./data/media
TIP_MEDIA_S3_BUCKET=
TIP_MEDIA_S3_REGION=us-west-2
TIP_MEDIA_S3_KMS_KEY_ID=                    # KMS key ARN for SSE-KMS
TIP_MEDIA_PRESIGN_TTL_SEC=300               # presigned-URL lifetime

# Upload size caps. Blank = protocol default (shared/constants MEDIA_LIMITS).
TIP_MAX_VIDEO_BYTES=
TIP_MAX_IMAGE_BYTES=
TIP_MAX_AUDIO_BYTES=
TIP_MAX_TEXT_BYTES=

# AWS creds: leave empty for ambient (EC2 role / IRSA). Set only for
# setup.sh trust_mode=keys (bucket-scoped user; rotate 90d).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Retention sweep runtime; the windows themselves are genesis constants.
# Values shown are the defaults (sweeper on, 6h interval).
# TIP_MEDIA_RETENTION_DISABLE=0
# TIP_MEDIA_RETENTION_SWEEP_INTERVAL_MS=21600000

# ─── AI Classifier / Prescan ─────────────────────────────────────────────────
TIP_CLASSIFIER_URL=http://localhost:6060
TIP_CLASSIFIER_KEY=                         # blank = dev mode (no auth)
# Fallback when the classifier is unreachable (1 = heuristic verdicts, tagged
# provider=local_fallback on chain; 0 = strict, content waits for cross-node fail-open).
TIP_CLASSIFIER_FALLBACK=1
TIP_CLASSIFIER_SCAN_NON_OH=false            # also scan self-disclosed AA/AG/MX; costly, keep false in prod
# In-flight classifier calls per worker; MUST match classifier throughput
# (single CPU dev classifier = 1, GPU/batched = 2-4).
TIP_PRESCAN_CONCURRENCY=1
TIP_PRESCAN_WORKER_COUNT=1                  # worker instances in this process
# TIP_PRESCAN_WORKER_DISABLE=1              # run the worker as a separate process

# ─── Logging ─────────────────────────────────────────────────────────────────
# Levels: debug > info > warn > error. debug.log always captures everything.
TIP_LOG_LEVEL=warn                          # file threshold (info.log)
TIP_CONSOLE_LEVEL=warn                      # terminal / docker logs threshold
TIP_LOG_DIR=./logs/node-1                   # per-node dir on multi-node hosts

# ─── API Limits ──────────────────────────────────────────────────────────────
TIP_CORS_ORIGINS=*                          # comma-separated; '*' for dev only
TIP_RATE_LIMIT_MAX=200                      # per-IP requests per window; raise for UAT load
TIP_RATE_LIMIT_WINDOW_MS=60000

# ─── Performance ─────────────────────────────────────────────────────────────
# Off-thread ML-DSA cert verification; keeps catch-up bursts off the consensus
# loop. Recommended: leave blank (auto = min(3, cpus-2)).
#   1-core VPS -> 0 (synchronous)   2-4 cores -> 1-2   8+ cores -> 3
#   Higher than 3 only on a big dedicated host that wants faster catch-up.
TIP_CRYPTO_POOL_SIZE=
# Peer health probe: the only timed job; consensus work is commit-event-driven.
TIP_PEER_HEALTH_MS=30000

# ─── Dev-only flags ──────────────────────────────────────────────────────────
# Ignored when NODE_ENV=production.
TIP_DEV_FORCE_PRESCAN_TIER=                 # high | critical | random; force flagged prescan verdicts

# ─── Tier-3 Local Tunables ───────────────────────────────────────────────────
# Per-node timing/capacity overrides; they do NOT touch genesis_hash, so nodes
# may differ without forking. Values shown are the defaults (pinned to
# shared/local-config.js by node/tests/local-config-guard.test.js).
# TIP_ROUND_TIMEOUT_MS=2000
# TIP_BATCH_WAIT_MS=500
# TIP_CONSENSUS_SUMMARY_INTERVAL_MS=60000
# TIP_ANTI_ENTROPY_INTERVAL_MS=4000
# TIP_ANTI_ENTROPY_PEER_TIMEOUT_MS=2000
# TIP_SYNC_RETRY_BASE_MS=1000
# TIP_SNAPSHOT_BUSY_RETRY_MS=5000
# TIP_ACK_STREAM_TIMEOUT_MS=3000
# TIP_SYNC_DIVERGENCE_GRACE_MS=30000
# TIP_ROTATION_COORD_REBROADCAST_INTERVAL_MS=1500
# TIP_HANDSHAKE_TIMEOUT_MS=10000
# TIP_CONNECTION_MONITOR_PING_TIMEOUT_FLOOR_MS=20000
# TIP_SYNC_TOTAL_TIMEOUT_MS=30000
# TIP_MAX_ROUND_DURATION_MS=300000
# TIP_MEMPOOL_MAX_SIZE=10000
# TIP_MEMPOOL_TX_TTL_SECONDS=300
# TIP_SYNC_BATCH_SIZE=100
# TIP_ORDERED_HASH_CACHE_SIZE=10000
# TIP_MAX_MSGS_PER_PEER_PER_SEC=100
# TIP_SYNC_MAX_RESPONSE_BYTES=1073741824
# TIP_SYNC_MAX_RETRIES=5
# TIP_HANDSHAKE_MAX_RETRIES=3
# TIP_GC_INTERVAL_COMMITS=10
# TIP_SNAPSHOT_BUSY_RETRY_ATTEMPTS=1
# TIP_FRONTIER_RECONCILE_LOOKBACK_ROUNDS=200
# TIP_ROTATION_REPAIR_TIMEOUT_MS=5000
# TIP_ROTATION_REPAIR_MAX_RESPONSE_BYTES=1048576
# TIP_PRODUCER_PAUSE_ESCALATE_MS=30000
# TIP_CHANNEL_HEAL_FAIL_THRESHOLD=5
# TIP_CHANNEL_HEAL_COOLDOWN_MS=30000
# TIP_HANDSHAKE_REHANDSHAKE_INTERVAL_MS=20000
# TIP_HANDSHAKE_REAUTH_GRACE_MS=15000
# TIP_SYNC_FROM_PEER_TOLERANCE_ROUNDS=20
