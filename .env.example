# TIP Protocol Node — copy to `.env` and customise. NEVER commit .env to git.

# ─── Node Identity ──────────────────────────────────────────────────────────
NODE_ENV=development                       # development | staging | production
TIP_NODE_ID=                               # auto-generated from hostname if blank
TIP_NODE_TYPE=full                         # full | light | vp | archive
TIP_REGION=US

# ─── Network ────────────────────────────────────────────────────────────────
PORT=4000                                  # REST API port
HOST=0.0.0.0
TIP_PUBLIC_URL=http://localhost:4000       # public URL surfaced in API responses
TIP_P2P_PORT=4001                          # libp2p port for consensus
TIP_PUBLIC_IP=                             # public IP for peer dial-back (cloud/multi-host)
TIP_BOOTSTRAP_PEERS=                       # comma-separated multiaddrs (peer's /health → p2p.bootstrap_addr)
TIP_ENABLE_MDNS=true                       # LAN auto-discovery; false in cloud

# ─── Consensus performance ──────────────────────────────────────────────────
# Off-thread ML-DSA cert verification (worker_threads). Moves a catch-up / rejoin
# burst of signature verifies off the main consensus loop so the node stays
# responsive instead of freezing. Blank = auto: min(3, max(1, cpus-2)) on a
# multi-core host (capped at 3 so verify never grabs many cores), 0 on a
# single-core host. Set 0 to force synchronous verify on the main thread, or a
# higher number on a big dedicated host that wants faster parallel catch-up.
TIP_CRYPTO_POOL_SIZE=                       # verify worker threads; blank=auto, 0=off

# ─── Storage ────────────────────────────────────────────────────────────────
TIP_DATA_DIR=./data
TIP_DB_PATH=./data/tip.db                  # only used when DB_DRIVER=sqlite

# ─── Media Storage ──────────────────────────────────────────────────────────
# fs = local disk (dev) · s3 = AWS S3 (prod). Per-node bucket — provision
# with infra/s3-media/setup.sh; it prints these values. docs/PROD_S3_SETUP.md
TIP_MEDIA_BACKEND=fs
TIP_MEDIA_FS_PATH=./data/media
TIP_MEDIA_S3_BUCKET=
TIP_MEDIA_S3_REGION=us-west-2
TIP_MEDIA_S3_KMS_KEY_ID=                   # KMS key ARN for SSE-KMS
TIP_MEDIA_PRESIGN_TTL_SEC=300              # presigned-URL lifetime

# AWS creds: leave empty for ambient (EC2 role / IRSA / Roles Anywhere).
# Set ONLY for setup.sh trust_mode=keys (bucket-scoped user; rotate 90d).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Retention sweep runtime (windows themselves are genesis constants:
# 21d base / 7d post-adjudication / 7d post-appeal / 24h orphans).
# TIP_MEDIA_RETENTION_DISABLE=1
# TIP_MEDIA_RETENTION_SWEEP_INTERVAL_MS=60000

# This node's public API origin (https://host[:port], no path). Announced
# on chain at boot so peers can redirect reviewers here for media bytes.
# The announce probe requires {url}/health to answer as THIS node.
TIP_API_ENDPOINT=

# ─── Database ───────────────────────────────────────────────────────────────
# DB_DRIVER: sqlite (dev) | postgres (prod default) | mariadb | mssql | oracle.
# Unset → postgres in production/staging, sqlite in development/test.
DB_DRIVER=postgres

# Which DB service `docker compose up` starts. Empty = none (external/sqlite).
COMPOSE_PROFILES=postgres

# DB_HOST: compose service name in Docker, `localhost` natively,
# `host.docker.internal` for a host-shared DB from inside a container.
# DB_PORT blank = driver default (5432 / 3306 / 1433 / 1521).
DB_HOST=localhost
DB_PORT=
DB_NAME=tip_protocol
DB_USER=tip
DB_PASSWORD=

DB_SSL=false                               # true for any cloud/managed DB
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# Oracle: DB_NAME=FREEPDB1 (service name). MSSQL: password needs upper+lower+
# digit+symbol min 8, avoid '#'; cloud MSSQL usually needs DB_SSL=true.

# ─── Security — Node Keys ───────────────────────────────────────────────────
# ML-DSA-65 keypair (hex). scripts/seed.js → founding node;
# scripts/register-node.js → additional nodes.
TIP_NODE_PRIVATE_KEY=
TIP_NODE_PUBLIC_KEY=

# ─── Logging ────────────────────────────────────────────────────────────────
# Levels: debug > info > warn > error. debug.log always captures everything.
TIP_LOG_LEVEL=warn                         # file threshold (info.log)
TIP_CONSOLE_LEVEL=warn                     # terminal / docker logs threshold
TIP_LOG_DIR=./logs/node-1                  # per-node dir on multi-node hosts

# ─── CORS ───────────────────────────────────────────────────────────────────
TIP_CORS_ORIGINS=*                         # comma-separated; '*' for dev only

# ─── AI Classifier ──────────────────────────────────────────────────────────
TIP_CLASSIFIER_URL=http://localhost:6060
TIP_CLASSIFIER_KEY=                        # blank = dev mode (no auth)

# Fallback when the classifier is missing/unreachable (default ON): text gets
# a local heuristic verdict, media fails open; tagged provider=local_fallback
# on chain. 0 = strict: no classifier → content waits for cross-node fail-open.
TIP_CLASSIFIER_FALLBACK=1

# Also send self-disclosed AA/AG/MX through the classifier (default: only OH).
# Costs more classifier calls; keep false in prod.
TIP_CLASSIFIER_SCAN_NON_OH=false

# In-flight classifier calls per worker. MUST match classifier throughput:
# single CPU dev classifier → 1; GPU/batched → 2-4; N replicas → up to N.
TIP_PRESCAN_CONCURRENCY=1
TIP_PRESCAN_WORKER_COUNT=1                 # worker instances in this process
# TIP_PRESCAN_WORKER_DISABLE=1             # run the worker as a separate process

# ─── Dev-only flags ─────────────────────────────────────────────────────────
# All ignored when NODE_ENV=production.
TIP_DEV_BYPASS_VOTE_WINDOWS=0              # skip commit/reveal wall-clock windows
TIP_DEV_ALLOW_LOCALHOST_DOMAINS=0          # allow localhost in /v1/domain/register
TIP_DEV_LOCALHOST_FETCH_HOST=              # e.g. host.docker.internal (loopback fetch from container)
TIP_DEV_FORCE_PRESCAN_TIER=                # high | critical | random — force flagged verdicts; blank = real classifier

# ─── Tier-3 Local Tunables (Issue #39) ─────────────────────────────────────
# Per-node timing / capacity overrides that do NOT touch genesis_hash; nodes may
# differ without breaking consensus, and changing one needs no cluster restart.
# Leave unset to use the protocol default. The values below are the RECOMMENDED
# defaults: to undo a local override, restore the knob to the value shown here.
# Kept equal to shared/local-config.js by node/tests/local-config-guard.test.js.
# TIP_ROUND_TIMEOUT_MS=2000
# TIP_BATCH_WAIT_MS=500
# TIP_CONSENSUS_SUMMARY_INTERVAL_MS=60000
# TIP_ANTI_ENTROPY_INTERVAL_MS=4000
# TIP_ANTI_ENTROPY_PEER_TIMEOUT_MS=2000
# TIP_SYNC_RETRY_BASE_MS=1000
# TIP_SNAPSHOT_BUSY_RETRY_MS=5000
# TIP_ACK_STREAM_TIMEOUT_MS=3000
# TIP_SYNC_DIVERGENCE_GRACE_MS=30000
# TIP_ROTATION_COORD_REBROADCAST_INTERVAL_MS=1500
# TIP_HANDSHAKE_TIMEOUT_MS=10000
# TIP_CONNECTION_MONITOR_PING_TIMEOUT_FLOOR_MS=20000
# TIP_SYNC_TOTAL_TIMEOUT_MS=30000
# TIP_MAX_ROUND_DURATION_MS=300000
# TIP_MEMPOOL_MAX_SIZE=10000
# TIP_MEMPOOL_TX_TTL_SECONDS=300
# TIP_SYNC_BATCH_SIZE=100
# TIP_ORDERED_HASH_CACHE_SIZE=10000
# TIP_MAX_MSGS_PER_PEER_PER_SEC=100
# TIP_SYNC_MAX_RESPONSE_BYTES=1073741824
# TIP_SYNC_MAX_RETRIES=5
# TIP_HANDSHAKE_MAX_RETRIES=3
# TIP_GC_INTERVAL_COMMITS=10
# TIP_SNAPSHOT_BUSY_RETRY_ATTEMPTS=1
