# TIP Protocol Node Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# NEVER use these placeholder values in production.

# ─── Core Node Settings ───────────────────────────────────────────────────────

# Node environment: development | staging | production
NODE_ENV=development

# Port for the REST API
TIP_API_PORT=4000

# Port for the gossip protocol
TIP_GOSSIP_PORT=4001

# Node identifier (auto-generated on first run if not set)
# TIP_NODE_ID=

# ─── Security (REQUIRED -- generate random 256-bit values for production) ─────

# CRITICAL: Change this before ANY network-facing deployment
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TIP_JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_generate_random_256_bit_value

# CRITICAL: Change this before ANY network-facing deployment
TIP_ADMIN_API_KEY=CHANGE_THIS_IN_PRODUCTION_generate_random_256_bit_value

# ─── Genesis Block ────────────────────────────────────────────────────────────

# The canonical genesis hash (compiled into production builds)
# This is the development genesis hash. Production uses the mainnet genesis hash.
# DO NOT use the development genesis hash in production.
TIP_GENESIS_HASH=52f08c352f8866b4000000000000000000000000000000000000000000000000
TIP_CHAIN_ID=tip-devnet-v2

# ─── Database ─────────────────────────────────────────────────────────────────

# SQLite database path (development)
TIP_DB_PATH=./data/tip_node.db

# For production, use PostgreSQL:
# TIP_DATABASE_URL=postgresql://user:password@localhost:5432/tip_protocol

# ─── Peer Network ─────────────────────────────────────────────────────────────

# Comma-separated list of bootstrap peer addresses
# Leave empty for isolated development node
TIP_BOOTSTRAP_PEERS=

# For mainnet (set after genesis block is finalised):
# TIP_BOOTSTRAP_PEERS=node1.theailab.org:4001,node2.theailab.org:4001

# Maximum number of peer connections
TIP_MAX_PEERS=50

# Gossip interval in milliseconds
TIP_GOSSIP_INTERVAL_MS=5000

# ─── Cryptography ─────────────────────────────────────────────────────────────

# Algorithm mode: hybrid (Ed25519 + ML-DSA-65 transition) | pq (ML-DSA-65 only)
# Use 'hybrid' during transition period (Years 1-3)
TIP_CRYPTO_MODE=hybrid

# Path to the node's signing keypair (generated on first run)
TIP_KEYPAIR_PATH=./data/node_keypair.json

# Node ML-DSA-65 signing keypair (hex-encoded)
# If not set, an ephemeral keypair is generated at startup (won't survive restart)
# Generate: node -e "const c = require('./shared/crypto'); const kp = c.generateMLDSAKeypair(); console.log('PRIVATE=' + kp.privateKey); console.log('PUBLIC=' + kp.publicKey)"
TIP_NODE_PRIVATE_KEY=
TIP_NODE_PUBLIC_KEY=

# ─── VP Node Settings (only for accredited Verification Providers) ─────────────

# Whether this node is operating as a VP
TIP_VP_MODE=false

# VP identifier (assigned at accreditation)
# TIP_VP_ID=

# VP Code of Conduct compliance version accepted
# TIP_VP_COC_VERSION=1.0

# ─── Merkle Root Publication ───────────────────────────────────────────────────

# Interval for publishing Merkle root to DAG (milliseconds)
# Default: every 6 hours (21600000 ms)
TIP_MERKLE_INTERVAL_MS=21600000

# ─── AI Pre-Scan ──────────────────────────────────────────────────────────────

# Pre-scan mode: stub (heuristic) | api (external classifier) | disabled
# Production MUST use 'api' mode with a trained ML classifier
TIP_PRESCAN_MODE=stub

# Pre-scan API endpoint (required when TIP_PRESCAN_MODE=api)
# TIP_PRESCAN_API_URL=https://prescan.theailab.org/v1/classify
# TIP_PRESCAN_API_KEY=your_prescan_api_key

# ─── Logging ─────────────────────────────────────────────────────────────────

# Log level: error | warn | info | debug
TIP_LOG_LEVEL=info

# Log format: json | pretty
TIP_LOG_FORMAT=pretty

# ─── CORS (for browser-facing deployments) ─────────────────────────────────────

# Comma-separated list of allowed origins (* for development only)
TIP_CORS_ORIGINS=*

# ─── Rate Limiting ────────────────────────────────────────────────────────────

# Requests per minute per IP for the public API
TIP_RATE_LIMIT_PUBLIC=100

# Requests per minute per IP for the admin API
TIP_RATE_LIMIT_ADMIN=20
