# TIP Protocol Node Configuration
# Copy this file to .env and customise before starting the node.
# NEVER commit .env to version control.

# ─── Node Identity ────────────────────────────────────────────────────────────

# Node environment
NODE_ENV=development

# Node identifier (auto-generated from hostname if not set)
TIP_NODE_ID=

# Node type: full | light | vp | archive
TIP_NODE_TYPE=full

# Node region
TIP_REGION=US

# ─── Network ─────────────────────────────────────────────────────────────────

# REST API port
PORT=4000

# Bind address
HOST=0.0.0.0

# Public URL (used in API responses)
TIP_PUBLIC_URL=http://localhost:4000

# ─── P2P / Consensus ────────────────────────────────────────────────────────

# libp2p P2P port (Narwhal/Bullshark consensus)
TIP_P2P_PORT=4001

# Public IP address of this node (for bootstrap_addr in health endpoint)
# Other nodes use this to connect. Required for remote/cloud deployments.
# Find your IP:
#   macOS:   ipconfig getifaddr en0
#   Linux:   hostname -I | awk '{print $1}'
#   Windows: ipconfig | findstr "IPv4"
#   Cloud:   curl -s ifconfig.me
TIP_PUBLIC_IP=

# Comma-separated libp2p bootstrap peer multiaddrs
# Get from the seed node's health endpoint: GET /health → data.p2p.bootstrap_addr
# Example: /ip4/203.0.113.50/tcp/4001/p2p/12D3KooWAbCdEf...
TIP_BOOTSTRAP_PEERS=

# Enable mDNS peer discovery (auto-discovers peers on same local network)
# Set to false for cloud/remote deployments — use TIP_BOOTSTRAP_PEERS instead
TIP_ENABLE_MDNS=true

# ─── Storage ─────────────────────────────────────────────────────────────────

# Data directory (used for SQLite file and other local artifacts)
TIP_DATA_DIR=./data

# ─── Database ────────────────────────────────────────────────────────────────
#
# DB_DRIVER selects the database engine. Switching databases requires only
# changing DB_DRIVER + the connection variables below — no code changes.
#
#   Driver value   Engine              npm package(s)
#   ─────────────────────────────────────────────────────────
#   postgres       PostgreSQL          pg             (already installed)
#   mariadb        MariaDB / MySQL     mysql2         (already installed)
#   mysql          MySQL               mysql2         (alias for mariadb)
#   mssql          SQL Server          mssql          (install separately — see below)
#   sqlserver      SQL Server          mssql          (alias for mssql)
#   oracle         Oracle Database     oracledb       (already installed)
#   sqlite         SQLite (local dev)  better-sqlite3 (already installed)
#
# When DB_DRIVER is unset the driver is inferred from NODE_ENV:
#   NODE_ENV=production / staging  → postgres
#   NODE_ENV=development / test    → sqlite
#
DB_DRIVER=sqlite

# ── Common connection parameters ─────────────────────────────────────────────
# Used by postgres, mariadb, mssql, and oracle.
# Leave DB_PORT blank to use the driver's default (5432 / 3306 / 1433 / 1521).
#
DATABASE_URL=
# DB_HOST must match the Docker service name when running in Docker Compose:
#   postgres → DB_HOST=postgres
#   mariadb  → DB_HOST=mariadb
#   oracle   → DB_HOST=oracle
#   local dev (outside Docker) → DB_HOST=localhost
DB_HOST=localhost
DB_PORT=
DB_NAME=tip_protocol
DB_USER=tip
DB_PASSWORD=

# TLS/SSL — set DB_SSL=true for any remote or cloud database.
DB_SSL=false
# Set to false ONLY in private networks with self-signed certificates.
DB_SSL_REJECT_UNAUTHORIZED=true

# Connection pool (applies to all server-side drivers).
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── PostgreSQL ───────────────────────────────────────────────────────────────
#   DB_DRIVER=postgres
#   DATABASE_URL=postgresql://tip:secret@localhost:5432/tip_protocol
#   — or use individual params below with DB_PORT=5432 —
#
# Install: pg is already in node/package.json dependencies.

# ── MariaDB / MySQL ───────────────────────────────────────────────────────────
#   DB_DRIVER=mariadb          (or: mysql)
#   DB_HOST=mariadb            # Docker service name (use localhost outside Docker)
#   DB_PORT=3306
#   DB_NAME=tip_protocol
#   DB_USER=tip
#   DB_PASSWORD=secret
#
# mysql2 is already in node/package.json — no extra install needed.
# Docker: docker compose -f docker-compose.local.yml --profile mariadb up mariadb node1 -d

# ── SQL Server ────────────────────────────────────────────────────────────────
#   DB_DRIVER=mssql            (or: sqlserver)
#   DB_HOST=localhost
#   DB_PORT=1433
#   DB_NAME=tip_protocol
#   DB_USER=tip
#   DB_PASSWORD=secret          # SA password — must meet SQL Server complexity:
#                               # uppercase + lowercase + digit + symbol, min 8 chars.
#                               # Avoid # in .env (parsed as comment).
#   DB_SSL=true
#   DB_SSL_REJECT_UNAUTHORIZED=false   # for dev with self-signed cert
#
# Docker: docker compose -f docker-compose.local.yml --profile mssql up -d
# Install: npm install --workspace=node mssql

# ── Oracle Database ───────────────────────────────────────────────────────────
#   DB_DRIVER=oracle
#   DB_HOST=oracle             # Docker service name (use localhost outside Docker)
#   DB_PORT=1521
#   DB_NAME=FREEPDB1           # Oracle service name (not SID)
#   DB_USER=tip                # node1; tip_node2/tip_node3/tip_node4 for other nodes
#   DB_PASSWORD=secret
#   — or set DATABASE_URL to a full connect string / TNS descriptor —
#
# oracledb is already in node/package.json — no extra install needed.
# oracledb 6+ uses thin-mode (no Oracle Instant Client required).
# Docker: docker compose -f docker-compose.local.yml --profile oracle up -d
# After first start, multi-node schemas are created automatically (scripts/oracle-init.sql).

# ── SQLite ────────────────────────────────────────────────────────────────────
# Path to the SQLite .db file (used when DB_DRIVER=sqlite)
TIP_DB_PATH=./data/tip.db

# ─── Security ────────────────────────────────────────────────────────────────

# Node ML-DSA-65 signing keypair (hex-encoded)
# Generated by: scripts/seed.js (founding node) or scripts/register-node.js (additional nodes)
# Without these, the node cannot participate in consensus or sign transactions.
TIP_NODE_PRIVATE_KEY=
TIP_NODE_PUBLIC_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated allowed origins (* for development only)
TIP_CORS_ORIGINS=*

# ─── Logging ─────────────────────────────────────────────────────────────────
#
# Two thresholds, independent:
#   TIP_LOG_LEVEL     — max level written to logs/{date}/info.log
#   TIP_CONSOLE_LEVEL — max level printed to the terminal / docker logs
#
# debug.log ALWAYS captures every level regardless of these settings, so you
# can investigate any time without restarting. error.log captures errors only.
#
# Recommended production setup:
#   TIP_LOG_LEVEL=info       (info.log keeps the operator-relevant stream)
#   TIP_CONSOLE_LEVEL=warn   (terminal stays quiet — only warnings/errors)
#
# For local development:
#   TIP_LOG_LEVEL=info
#   TIP_CONSOLE_LEVEL=info   (default — see what's happening as you work)
#
# When investigating a bug:
#   TIP_CONSOLE_LEVEL=debug  (firehose on terminal — or just tail debug.log)
#
# Levels (highest to lowest verbosity): debug > info > warn > error
# Setting a level shows that level AND all more-severe levels.
#
# Log level for info.log file (default: info)
TIP_LOG_LEVEL=info

# Log level for console output (default: same as TIP_LOG_LEVEL, falls back to info)
# Set to `warn` in production to keep the terminal quiet — the full stream is
# still captured in logs/{date}/debug.log for post-mortem.
TIP_CONSOLE_LEVEL=warn