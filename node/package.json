{
  "name": "@tip-protocol/node",
  "version": "1.0.0",
  "description": "TIP Protocol full node — federated DAG, REST API, trust scoring engine",
  "main": "src/index.js",
  "author": "Dinesh Mendhe <chairman@theailab.org>",
  "license": "SEE LICENSE IN ../LICENSE.txt",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --experimental-vm-modules ../node_modules/.bin/jest --runInBand --forceExit",
    "test:watch": "../node_modules/.bin/jest --watch",
    "test:coverage": "../node_modules/.bin/jest --coverage --forceExit",
    "lint": "eslint src/ tests/ --ext .js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "morgan": "^1.10.0",
    "ws": "^8.16.0",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0",
    "ajv": "^8.12.0",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "eslint": "^8.57.0",
    "circomlib": "^2.0.5"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "testTimeout": 30000
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publisher": "The AI Lab Intelligence Unobscured, Inc.",
  "contributors": [
    {
      "name": "Dinesh Mendhe",
      "email": "chairman@theailab.org",
      "role": "Inventor and Author"
    },
    {
      "name": "The AI Lab Intelligence Unobscured, Inc.",
      "email": "chairman@theailab.org",
      "url": "https://theailab.org"
    }
  ]
}
