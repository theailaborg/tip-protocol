{
  "name": "@tip-protocol/node",
  "version": "2.0.0",
  "description": "TIP Protocol full node — federated DAG, REST API, trust scoring engine",
  "main": "src/index.js",
  "author": "Dinesh Mendhe <chairman@theailab.org>",
  "license": "SEE LICENSE IN ../LICENSE.txt",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --experimental-vm-modules ../node_modules/.bin/jest --runInBand --forceExit",
    "test:watch": "../node_modules/.bin/jest --watch",
    "test:coverage": "../node_modules/.bin/jest --coverage --forceExit",
    "lint": "eslint src/ tests/ --ext .js"
  },
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "^14.1.2",
    "@chainsafe/libp2p-noise": "^16.1.0",
    "@chainsafe/libp2p-yamux": "^7.0.4",
    "@libp2p/bootstrap": "^11.0.18",
    "@libp2p/identify": "^3.0.18",
    "@libp2p/mdns": "^11.0.17",
    "@libp2p/peer-id": "^5.0.12",
    "@libp2p/tcp": "^10.0.17",
    "ajv": "^8.12.0",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "knex": "^3.2.9",
    "libp2p": "^2.10.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.11.0",
    "oracledb": "^6.10.0",
    "pg": "^8.20.0",
    "protobufjs": "^8.0.1",
    "snarkjs": "^0.7.6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "circomlib": "^2.0.5",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFiles": [
      "<rootDir>/tests/jest-setup.js"
    ],
    "reporters": [
      "default",
      "<rootDir>/tests/_failures-summary-reporter.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "testTimeout": 30000
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publisher": "The AI Lab Intelligence Unobscured, Inc.",
  "contributors": [
    {
      "name": "Dinesh Mendhe",
      "email": "chairman@theailab.org",
      "role": "Inventor and Author"
    },
    {
      "name": "The AI Lab Intelligence Unobscured, Inc.",
      "email": "chairman@theailab.org",
      "url": "https://theailab.org"
    }
  ]
}
