# Copy to .env (same directory as docker-compose.yml) and customise.
# `.env` is git-ignored — never commit it.
#
# Defaults below match the local-dev setup; OK to leave as-is for loopback.

# ── Grafana ────────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
GF_HTTP_PORT=3030
# Set to "false" before exposing Grafana on any non-loopback interface.
GF_ANON_ENABLED=true

# ── Prometheus ─────────────────────────────────────────────────────────────
PROM_HTTP_PORT=9090
PROM_RETENTION=7d
