# Copy to .env (same directory as docker-compose.yml) and customise.
# `.env` is git-ignored — never commit it.
#
# Defaults below match the local-dev setup; OK to leave as-is for loopback.

# ── Grafana ────────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
GF_HTTP_PORT=3030
# Set to "false" before exposing Grafana on any non-loopback interface.
GF_ANON_ENABLED=true

# ── Prometheus ─────────────────────────────────────────────────────────────
PROM_HTTP_PORT=9090
PROM_RETENTION=7d

# Comma-separated list of TIP node `host:port` to scrape. Default covers the
# 5-node local-dev federation. To add or remove a node, edit this list and
# restart the prometheus container — no edit of prometheus.yml needed.
# `host.docker.internal` resolves to the host machine from inside the
# prom container (Linux/Mac/Windows via the extra_hosts mapping).
TIP_NODE_TARGETS=host.docker.internal:4000,host.docker.internal:4100,host.docker.internal:4200,host.docker.internal:4300,host.docker.internal:4400
