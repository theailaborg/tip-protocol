    {
      "id": 50,
      "type": "table",
      "title": "Federation status \u2014 registered nodes, online state, connections",
      "description": "One row per TIP node in the DAG registry. Status = registered status from the DAG. Online = whether the node is currently emitting metrics. Connected to = peers it currently sees (only populated for online nodes). Empty cells for offline nodes.",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "targets": [
        {
          "refId": "Registry",
          "expr": "group by (node, name, status) (tip_node_registry_info)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "Online",
          "expr": "group by (node) (tip_process_uptime_seconds)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "Peers",
          "expr": "group by (node, peers) (tip_network_peer_list)",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "node",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "__name__ 3": true,
              "__name__ 4": true,
              "instance 1": true,
              "instance 2": true,
              "instance 3": true,
              "instance 4": true,
              "job 1": true,
              "job 2": true,
              "job 3": true,
              "job 4": true,
              "federation 1": true,
              "federation 2": true,
              "federation 3": true,
              "federation 4": true,
              "exported_node 1": true,
              "exported_node 2": true,
              "exported_node 3": true,
              "exported_node 4": true,
              "role 1": true,
              "role 2": true,
              "role 3": true,
              "role 4": true,
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "federation": true,
              "exported_node": true,
              "role": true,
              "Value": true,
              "Value #Registry": true,
              "Value #Peers": true
            },
            "indexByName": {
              "node": 0,
              "name": 1,
              "status": 2,
              "Value #Online": 3,
              "peers": 4
            },
            "renameByName": {
              "node": "Node",
              "name": "Name",
              "status": "Status",
              "Value #Online": "Online",
              "peers": "Connected to"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "active": {
                        "text": "active",
                        "color": "green"
                      },
                      "inactive": {
                        "text": "inactive",
                        "color": "orange"
                      },
                      "revoked": {
                        "text": "revoked",
                        "color": "red"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Online"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "1": {
                        "text": "online",
                        "color": "green"
                      }
                    }
                  },
                  {
                    "type": "special",
                    "options": {
                      "match": "null",
                      "result": {
                        "text": "offline",
                        "color": "red"
                      }
                    }
                  },
                  {
                    "type": "special",
                    "options": {
                      "match": "empty",
                      "result": {
                        "text": "offline",
                        "color": "red"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "noValue",
                "value": "offline"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Connected to"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "": {
                        "text": "(none \u2014 isolated)",
                        "color": "orange"
                      }
                    }
                  },
                  {
                    "type": "special",
                    "options": {
                      "match": "null",
                      "result": {
                        "text": "(offline)",
                        "color": "red"
                      }
                    }
                  },
                  {
                    "type": "special",
                    "options": {
                      "match": "empty",
                      "result": {
                        "text": "(none \u2014 isolated)",
                        "color": "orange"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "noValue",
                "value": "(offline)"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      }
    },
