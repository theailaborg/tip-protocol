    {
      "id": 25,
      "type": "timeseries",
      "title": "Offered vs committed tx rate (/min)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Federation tx funnel: offered (into mempool), batched, committed (finalized).\n\nCapacity = the highest *offered* rate where *committed* still tracks it.\nAct if: committed flatlines below offered, you've hit the ceiling (see the backlog panel).",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(tip_mempool_received_total[1m])) * 60",
          "legendFormat": "offered (received)"
        },
        {
          "refId": "B",
          "expr": "sum(rate(tip_mempool_drained_total[1m])) * 60",
          "legendFormat": "batched (drained)"
        },
        {
          "refId": "C",
          "expr": "sum(rate(tip_bullshark_txs_committed_total[1m])) * 60",
          "legendFormat": "committed (throughput)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
