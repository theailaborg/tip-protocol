{
  "uid": "tip-consensus-health",
  "title": "TIP Consensus Health",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "tags": [
    "tip",
    "consensus",
    "health"
  ],
  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prom-tip"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "query": {
          "query": "label_values(tip_node_registry_info, node)",
          "refId": "vars"
        },
        "refresh": 2,
        "sort": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "ACTION NEEDED?  (green = healthy, red = investigate)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Halted nodes",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Nodes whose consensus halt-gate is tripped (stale rounds / sub-quorum / fork).\n\nNormal: 0.\nAct if: >0 sustained, a node has stopped finalizing.",
      "targets": [
        {
          "refId": "A",
          "expr": "count(tip_consensus_halted == 1) or vector(0)",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "0 HEALTHY"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 4
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Nodes online",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Nodes whose /metrics responded to the last scrape.\n\nNormal: 5.\nAct if: <4 (below quorum), a node's thread is blocked or it crashed.",
      "targets": [
        {
          "refId": "A",
          "expr": "count(up{job=\"tip-federation\"} == 1) or vector(0)",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 4
              },
              {
                "color": "green",
                "value": 5
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 8,
        "h": 4
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Quorum margin (min)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Smallest (active participants minus quorum) across the federation.\n\nNormal: >=1.\nAct if: 0, the federation is at the edge; any single drop halts it.",
      "targets": [
        {
          "refId": "A",
          "expr": "min(tip_consensus_quorum_margin)",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 8,
        "h": 4
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Worst event-loop stall",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Longest single event-loop block in the federation (last 1s window).\n\nNormal: <250ms.\nAct if: >1000ms sustained, the thread is starved; that node drops peers and goes offline.",
      "targets": [
        {
          "refId": "A",
          "expr": "max(tip_process_event_loop_lag_max_ms)",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 250
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 8,
        "h": 4
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Suspect peers",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Peers any node currently can't reach via heartbeat.\n\nNormal: 0.\nAct if: >0 sustained, each suspect triggers an anti-entropy sync storm (the jitter feedback loop).",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(tip_heartbeat_suspect_peers) or vector(0)",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "0 CALM"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "gridPos": {
        "x": 8,
        "y": 5,
        "w": 8,
        "h": 4
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Commit rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Anchors committed per minute across the federation.\n\nNormal: >0 (advancing).\nAct if: 0, consensus is not finalizing anything.",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(tip_bullshark_anchors_committed_total[2m])) * 60 or vector(0)",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 0.5
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "gridPos": {
        "x": 16,
        "y": 5,
        "w": 8,
        "h": 4
      }
    },
    {
      "id": 8,
      "type": "row",
      "title": "Consensus progress",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Committed round per node",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "The last round each node finalized.\n\nNormal: all lines rise together, tightly bunched.\nAct if: a line flatlines (that node stalled) or sits far below the others (sync gap).",
      "targets": [
        {
          "refId": "A",
          "expr": "(tip_bullshark_last_committed_round{node=~\"$node\"} * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Commit spread: leader minus laggard",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "How many rounds the most-behind node trails the leader.\n\nNormal: <5.\nAct if: >20 sustained, a node is falling behind and anti-entropy isn't closing the gap.",
      "targets": [
        {
          "refId": "A",
          "expr": "max(tip_bullshark_last_committed_round) - min(tip_bullshark_last_committed_round)",
          "legendFormat": "spread (rounds)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 10,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 11,
      "type": "row",
      "title": "Jitter & event-loop stalls  (the root signal)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Event-loop stall per node (ms)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Longest thread block per node, per 1s window. The two lines mark warn (250ms) and act (1s).\n\nNormal: flat <250ms.\nAct if: repeated spikes >1s, the node can't serve /metrics or send keepalives during the block, so it flips offline and drops peers.",
      "targets": [
        {
          "refId": "A",
          "expr": "(tip_process_event_loop_lag_max_ms{node=~\"$node\"} * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 250
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Nodes online over time",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Per-node scrape success (1 = online).\n\nNormal: flat at 1 for all.\nAct if: a line dips to 0, that node's thread stalled past the scrape timeout (correlate with the stall panel on the left).",
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"tip-federation\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 22,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Disconnects per node (/min)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Rate of libp2p peer disconnects.\n\nNormal: ~0.\nAct if: sustained spikes, peers are flapping (usually downstream of a stall; recovered by fast-reauth but still disrupts a round).",
      "targets": [
        {
          "refId": "A",
          "expr": "(rate(tip_network_peer_disconnects_total{node=~\"$node\"}[2m]) * 60 * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Fast re-auths per node (/min)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Reconnects restored within the 15s grace window (no full handshake).\n\nNormal: ~0.\nAct if: tracks the disconnect rate and stays high, confirms hard peer flapping is ongoing.",
      "targets": [
        {
          "refId": "A",
          "expr": "(rate(tip_network_fast_reauths_total{node=~\"$node\"}[2m]) * 60 * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 33,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 16,
      "type": "row",
      "title": "Feedback loop  (why the jitter sustains)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 44,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Heartbeat suspect peers",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Peers each node currently marks suspect (missed heartbeats).\n\nNormal: 0.\nAct if: >0 sustained, this is the trigger: suspect, then anti-entropy reconcile, then sync storm.",
      "targets": [
        {
          "refId": "A",
          "expr": "(tip_heartbeat_suspect_peers{node=~\"$node\"} * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 45,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Anti-entropy gap-pulls (/min)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Rate each node pulls cert gaps from peers.\n\nNormal: occasional.\nAct if: sustained high, the cluster is in a sync storm, burning CPU that deepens the stalls.",
      "targets": [
        {
          "refId": "A",
          "expr": "(rate(tip_antientropy_gaps_pulled_total{node=~\"$node\"}[2m]) * 60 * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 45,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Pending / parked certs",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Certs parked waiting on missing parents before an anchor can commit.\n\nNormal: 0 to low.\nAct if: climbs, anchors can't finalize because parent certs haven't arrived (a peer is behind/stalled).",
      "targets": [
        {
          "refId": "A",
          "expr": "(tip_narwhal_pending_certs{node=~\"$node\"} * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
