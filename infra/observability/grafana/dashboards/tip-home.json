{
  "uid": "tip-home",
  "title": "TIP Overview",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "tags": [
    "tip",
    "consensus",
    "health"
  ],
  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prom-tip"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "query": {
          "query": "label_values(tip_node_registry_info, node)",
          "refId": "vars"
        },
        "refresh": 2,
        "sort": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 3000,
      "type": "row",
      "title": "Fleet health at a glance",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 3001,
      "type": "stat",
      "title": "Halted nodes",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(tip_consensus_halted) or vector(0)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "description": "Nodes that have halted consensus. 0 is healthy."
    },
    {
      "id": 3002,
      "type": "stat",
      "title": "Nodes online",
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(group by (node) (tip_node_registry_info))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "description": "Nodes currently in the registry."
    },
    {
      "id": 3003,
      "type": "stat",
      "title": "Byzantine fork (active)",
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(tip_consensus_byzantine_fork_halted) or vector(0)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "description": "1 if ANY node is currently fork-halted (active byzantine fork) - red is a real, present-tense emergency. 0 is healthy. This is the active-state gauge, not the lifetime divergence counter (that cumulative count, which never resets, lives on the Consensus Health dashboard as a 15m rate)."
    },
    {
      "id": 3004,
      "type": "stat",
      "title": "Quorum margin (min)",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "min(tip_consensus_quorum_margin)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "green",
                "value": 2
              }
            ]
          }
        }
      },
      "description": "Active participants beyond quorum on the weakest node. 0 = one drop halts."
    },
    {
      "id": 3005,
      "type": "stat",
      "title": "Committed round (max)",
      "gridPos": {
        "x": 8,
        "y": 5,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(tip_bullshark_last_committed_round)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "description": "Highest committed round across the fleet."
    },
    {
      "id": 3006,
      "type": "stat",
      "title": "Rotation number",
      "gridPos": {
        "x": 16,
        "y": 5,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(tip_committee_current_rotation_number)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "description": "Current committee rotation number."
    },
    {
      "id": 3007,
      "type": "row",
      "title": "Dashboards",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 3008,
      "type": "dashlist",
      "title": "All TIP dashboards",
      "datasource": null,
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 24,
        "h": 12
      },
      "options": {
        "showSearch": true,
        "showHeadings": false,
        "showRecentlyViewed": false,
        "showStarred": false,
        "maxItems": 30,
        "tags": [
          "tip"
        ],
        "includeVars": false,
        "keepTime": false
      }
    }
  ]
}
