    {
      "id": 518,
      "type": "row",
      "title": "Heartbeat",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 65,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 519,
      "type": "timeseries",
      "title": "Heartbeat suspect peers",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Peers each node currently marks suspect (missed heartbeats).\n\nNormal: 0.\nAct if: >0 sustained, this is the trigger: suspect, then anti-entropy reconcile, then sync storm.",
      "targets": [
        {
          "refId": "A",
          "expr": "(tip_heartbeat_suspect_peers{node=~\"$node\"} * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 66,
        "w": 24,
        "h": 11
      }
    },
    {
      "id": 520,
      "type": "row",
      "title": "Comms health  (per-channel outbound delivery + transport auto-heal)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 77,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 521,
      "type": "timeseries",
      "title": "Outbound send failures per peer (/min)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Direct-stream send failures from a node to a peer. A line that climbs while the peer stays connected is a silent one-directional partition (the rotation-halt root cause).",
      "targets": [
        {
          "refId": "A",
          "expr": "rate(tip_network_peer_send_failures_total{node=~\"$node\"}[5m]) * 60",
          "legendFormat": "{{node}} -> {{peer}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 78,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 522,
      "type": "timeseries",
      "title": "Time since last successful send (per peer)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Milliseconds since the last successful outbound send to a peer. High while connected = a broken outbound push.",
      "targets": [
        {
          "refId": "A",
          "expr": "tip_network_peer_last_send_ok_age_ms{node=~\"$node\"}",
          "legendFormat": "{{node}} -> {{peer}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 78,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 523,
      "type": "timeseries",
      "title": "Transport auto-heals (/min)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Force-close + re-dial events that rebuild a half-dead connection after sustained one-directional send failures. Spikes mean the auto-heal fired.",
      "targets": [
        {
          "refId": "A",
          "expr": "(rate(tip_network_force_redials_total{node=~\"$node\"}[2m]) * 60 * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 89,
        "w": 12,
        "h": 11
      }
    }
  ]
