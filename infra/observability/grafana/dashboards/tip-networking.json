{
  "uid": "tip-networking",
  "title": "TIP Networking",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "tags": [
    "tip",
    "consensus",
    "health"
  ],
  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prom-tip"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "query": {
          "query": "label_values(tip_node_registry_info, node)",
          "refId": "vars"
        },
        "refresh": 2,
        "sort": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 500,
      "type": "row",
      "title": "Connectivity",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 501,
      "type": "timeseries",
      "title": "Authorized peers per node",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Connected + handshaked committee peers.\n\nNormal: 4 (for a 5-node committee).\nAct if: <4 on any node, it lost a committee peer (reduces its quorum view).",
      "targets": [
        {
          "refId": "A",
          "expr": "(tip_network_peers_authorized{node=~\"$node\"} * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 4
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 502,
      "type": "timeseries",
      "title": "Connectivity complete (1 = full mesh)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "1 when a node is connected to every active committee member.\n\nNormal: 1 for all.\nAct if: drops to 0, that node is missing a peer and may park commits.",
      "targets": [
        {
          "refId": "A",
          "expr": "(tip_network_connectivity_complete{node=~\"$node\"} * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 503,
      "type": "row",
      "title": "Connection churn (the flap signal)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 504,
      "type": "timeseries",
      "title": "Connects per node (/min)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "libp2p peer:connect rate. Paired with disconnects, this is the flap that reads as 'node goes offline randomly'.",
      "targets": [
        {
          "refId": "A",
          "expr": "(rate(tip_network_peer_connects_total{node=~\"$node\"}[2m]) * 60 * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 505,
      "type": "timeseries",
      "title": "Disconnects per node (/min)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Rate of libp2p peer disconnects.\n\nNormal: ~0.\nAct if: sustained spikes, peers are flapping (usually downstream of a stall; recovered by fast-reauth but still disrupts a round).",
      "targets": [
        {
          "refId": "A",
          "expr": "(rate(tip_network_peer_disconnects_total{node=~\"$node\"}[2m]) * 60 * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 13,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 506,
      "type": "timeseries",
      "title": "Connection closes per node (/min)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "libp2p connection:close rate (incl. pre-auth) - the rawest flap signal.",
      "targets": [
        {
          "refId": "A",
          "expr": "(rate(tip_network_connection_closes_total{node=~\"$node\"}[2m]) * 60 * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 507,
      "type": "timeseries",
      "title": "Fast re-auths per node (/min)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Reconnects restored within the 15s grace window (no full handshake).\n\nNormal: ~0.\nAct if: tracks the disconnect rate and stays high, confirms hard peer flapping is ongoing.",
      "targets": [
        {
          "refId": "A",
          "expr": "(rate(tip_network_fast_reauths_total{node=~\"$node\"}[2m]) * 60 * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 508,
      "type": "timeseries",
      "title": "Re-handshakes per node (/min)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Re-handshakes of connected-but-unauthorized peers (recovery of a stale auth window).",
      "targets": [
        {
          "refId": "A",
          "expr": "(rate(tip_network_rehandshakes_total{node=~\"$node\"}[2m]) * 60 * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 509,
      "type": "row",
      "title": "Heartbeat",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 46,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 510,
      "type": "timeseries",
      "title": "Heartbeat suspect peers",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Peers each node currently marks suspect (missed heartbeats).\n\nNormal: 0.\nAct if: >0 sustained, this is the trigger: suspect, then anti-entropy reconcile, then sync storm.",
      "targets": [
        {
          "refId": "A",
          "expr": "(tip_heartbeat_suspect_peers{node=~\"$node\"} * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 47,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 511,
      "type": "stat",
      "title": "Suspect peers",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Peers any node currently can't reach via heartbeat.\n\nNormal: 0.\nAct if: >0 sustained, each suspect triggers an anti-entropy sync storm (the jitter feedback loop).",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(tip_heartbeat_suspect_peers) or vector(0)",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "0 CALM"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "gridPos": {
        "x": 12,
        "y": 47,
        "w": 8,
        "h": 4
      }
    },
    {
      "id": 512,
      "type": "row",
      "title": "Comms health  (per-channel outbound delivery + transport auto-heal)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 58,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 513,
      "type": "timeseries",
      "title": "Outbound send failures per peer (/min)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Direct-stream send failures from a node to a peer. A line that climbs while the peer stays connected is a silent one-directional partition (the rotation-halt root cause).",
      "targets": [
        {
          "refId": "A",
          "expr": "rate(tip_network_peer_send_failures_total{node=~\"$node\"}[5m]) * 60",
          "legendFormat": "{{node}} -> {{peer}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 59,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 514,
      "type": "timeseries",
      "title": "Time since last successful send (per peer)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Milliseconds since the last successful outbound send to a peer. High while connected = a broken outbound push.",
      "targets": [
        {
          "refId": "A",
          "expr": "tip_network_peer_last_send_ok_age_ms{node=~\"$node\"}",
          "legendFormat": "{{node}} -> {{peer}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 59,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 515,
      "type": "timeseries",
      "title": "Transport auto-heals (/min)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Force-close + re-dial events that rebuild a half-dead connection after sustained one-directional send failures. Spikes mean the auto-heal fired.",
      "targets": [
        {
          "refId": "A",
          "expr": "(rate(tip_network_force_redials_total{node=~\"$node\"}[2m]) * 60 * on(node) group_left(name) (group by (node, name) (tip_node_registry_info)))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 70,
        "w": 12,
        "h": 11
      }
    }
  ]
}
