{
  "uid": "tip-rotation",
  "title": "TIP Rotation Health",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "tags": [
    "tip",
    "consensus",
    "health"
  ],
  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prom-tip"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "query": {
          "query": "label_values(tip_node_registry_info, node)",
          "refId": "vars"
        },
        "refresh": 2,
        "sort": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1500,
      "type": "row",
      "title": "Rotation status  (green = healthy, red = investigate)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 1501,
      "type": "stat",
      "title": "Current rotation number",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(tip_committee_current_rotation_number)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "description": "Latest committee rotation_number in committee_history (0 = genesis)."
    },
    {
      "id": 1502,
      "type": "stat",
      "title": "Committee history size",
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(tip_committee_history_size)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "description": "Total rows in committee_history (includes the rotation-0 bootstrap)."
    },
    {
      "id": 1503,
      "type": "stat",
      "title": "Rotation failures (/min)",
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(tip_committee_rotation_failures_total[10m])) * 60 or vector(0)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "decimals": 2
        }
      },
      "description": "Genuine rotation rejections per minute (insufficient sigs / payload mismatch; benign re-broadcast duplicates excluded). 0 is healthy. Real health = the rotation number advancing."
    },
    {
      "id": 1504,
      "type": "row",
      "title": "Rotation pipeline",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 1505,
      "type": "timeseries",
      "title": "Rotation proposals / commits / failures (/min)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Proposer attempts vs rotations that landed in committee_history vs commit-handler rejections. Proposals with no commits = a stuck rotation boundary.",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(tip_committee_rotation_proposals_total[10m])) * 60",
          "legendFormat": "proposals"
        },
        {
          "refId": "B",
          "expr": "sum(rate(tip_committee_rotation_committed_total[10m])) * 60",
          "legendFormat": "committed"
        },
        {
          "refId": "C",
          "expr": "sum(rate(tip_committee_rotation_failures_total[10m])) * 60",
          "legendFormat": "failures"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 24,
        "h": 11
      }
    },
    {
      "id": 1506,
      "type": "timeseries",
      "title": "Current rotation number per node",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Each node's view of the current rotation_number. A node lagging the others has not applied the latest rotation.",
      "targets": [
        {
          "refId": "A",
          "expr": "tip_committee_current_rotation_number{node=~\"$node\"} * on(node) group_left(name) (group by (node, name) (tip_node_registry_info))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 12,
        "h": 11
      }
    },
    {
      "id": 1507,
      "type": "timeseries",
      "title": "Producer-pause stuck duration per node",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-tip"
      },
      "description": "Milliseconds producer-paused at the boundary with no tx to carve. Sustained > 0 = the boundary is stuck; pull-repair runs without bypassing the pause.",
      "targets": [
        {
          "refId": "A",
          "expr": "tip_consensus_producer_paused_ms{node=~\"$node\"} * on(node) group_left(name) (group by (node, name) (tip_node_registry_info))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 17,
        "w": 12,
        "h": 11
      }
    }
  ]
}
